{
  "name": "@mukundakatta/jmespath-mcp",
  "version": "0.1.0",
  "description": "MCP server for JMESPath JSON queries. Pure-JS, no native binary. AWS-style data extraction LLMs can call reliably.",
  "type": "module",
  "main": "src/index.js",
  "bin": { "jmespath-mcp": "src/index.js" },
  "files": ["src", "README.md", "LICENSE-MIT", "LICENSE-APACHE", "server.json"],
  "scripts": { "start": "node src/index.js", "test": "node --test tests/test.js" },
  "keywords": ["mcp", "jmespath", "json", "query", "llm"],
  "author": "Mukunda Katta <mukunda.vjcs6@gmail.com>",
  "license": "MIT OR Apache-2.0",
  "repository": { "type": "git", "url": "git+https://github.com/MukundaKatta/mcp-stack.git", "directory": "packages/jmespath-mcp" },
  "homepage": "https://github.com/MukundaKatta/mcp-stack/tree/main/packages/jmespath-mcp",
  "bugs": "https://github.com/MukundaKatta/mcp-stack/issues",
  "engines": { "node": ">=18" },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jmespath": "^0.16.0"
  },
  "mcpName": "io.github.MukundaKatta/jmespath-mcp"
}
